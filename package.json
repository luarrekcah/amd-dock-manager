{
  "name": "amd-dock-manager",
  "version": "0.0.1",
  "description": "QEMU TCG Docker Manager for AMD Hackintosh - Bypasses HVF using software emulation",
  "main": "src/main/main.js",
  "homepage": "https://github.com/devluar/amd-dock-manager",
  "author": "devluar",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "lint": "eslint src/**/*.js",
    "setup": "bash scripts/setup.sh"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.9",
    "node-pty": "^0.10.1",
    "systeminformation": "^5.21.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.devluar.amd-dock-manager",
    "productName": "AMD Dock Manager",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "luarrekcah",
        "repo": "amd-dock-manager"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/luarrekcah/amd-dock-manager.git"
  }
}
